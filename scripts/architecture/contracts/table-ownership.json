    },
    {
      "name": "appSettings",
      "ownerDomain": "settings",
      "allowedDirectAccessSummary": "settings, infra/storage",
      "allowedDirectAccessPaths": [
        "src/domains/settings/**/*.ts",
        "src/domains/settings/**/*.tsx",
        "src/infra/storage/primary.ts"
      ],
      "allowedApplicationPaths": [],
