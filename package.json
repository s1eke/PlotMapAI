{
  "name": "plotmapai",
  "private": true,
  "version": "1.1.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:debug": "VITE_DEBUG=true vite",
    "build": "tsc -b && vite build && node scripts/checkBundleBudget.mjs",
    "analyze": "ANALYZE_BUNDLE=1 npm run build",
    "generate:pwa-icons": "node scripts/generateMaskableIcons.mjs",
    "lint": "eslint . && node scripts/checkReaderArchitecture.mjs --strict",
    "preview": "vite preview",
    "test": "vitest run",
    "test:visual": "playwright test",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.5",
    "@tailwindcss/vite": "^4.2.1",
    "@xmldom/xmldom": "^0.9.9",
    "clsx": "^2.1.1",
    "dexie": "^4.4.0",
    "i18next": "^24.2.2",
    "i18next-browser-languagedetector": "^8.1.8",
    "js-yaml": "^4.1.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.577.0",
    "motion": "^12.38.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^15.4.0",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.39.4",
    "eslint-config-ali": "^16.6.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.0.0",
    "msw": "^2.12.13",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "vite": "^8.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5",
    "vite": "^8.0.0"
  }
}
